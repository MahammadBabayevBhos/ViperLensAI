<!DOCTYPE html>
<html lang="en" class="h-full bg-slate-950">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/public/css/styles.css" />
</head>
<body class="h-full bg-gradient-to-br from-cyber-900 via-cyber-800 to-cyber-900 text-slate-100 antialiased">
  <main class="mx-auto max-w-6xl px-6 py-10">
    <header class="mb-6 flex items-center justify-between border-b border-slate-800 pb-5">
      <div>
        <p class="text-xs uppercase tracking-[0.3em] text-sky-400">Account Intelligence</p>
        <h1 class="mt-2 text-3xl font-semibold">Analysis History</h1>
      </div>
      <div class="flex items-center gap-3">
        <a href="/profile" class="rounded-lg border border-slate-700 px-4 py-2 text-sm text-slate-200 hover:bg-slate-900">Profile</a>
        <a href="/" class="rounded-lg border border-slate-700 px-4 py-2 text-sm text-slate-200 hover:bg-slate-900">Back to Dashboard</a>
        <form action="/logout" method="POST">
          <button type="submit" class="rounded-lg border border-slate-700 px-4 py-2 text-sm text-slate-200 hover:bg-slate-900">Logout</button>
        </form>
      </div>
    </header>

    <% if (error) { %>
      <div class="mb-4 rounded-lg border border-red-500/40 bg-red-500/10 px-4 py-3 text-sm text-red-200"><%= error %></div>
    <% } %>

    <section class="overflow-hidden rounded-xl border border-slate-800 bg-slate-900/70">
      <table class="w-full text-left text-sm">
        <thead class="bg-slate-900 text-slate-300">
          <tr>
            <th class="px-4 py-3">File Name</th>
            <th class="px-4 py-3">Verdict</th>
            <th class="px-4 py-3">Confidence</th>
            <th class="px-4 py-3">Status</th>
            <th class="px-4 py-3">Timestamp</th>
            <th class="px-4 py-3">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (!historyItems.length) { %>
            <tr class="border-t border-slate-800"><td colspan="6" class="px-4 py-6 text-center text-slate-400">No scans yet. Run your first analysis from the dashboard.</td></tr>
          <% } %>
          <% historyItems.forEach((item) => { %>
            <tr class="border-t border-slate-800">
              <td class="px-4 py-3 text-slate-200"><%= item.file_name %></td>
              <td class="px-4 py-3 uppercase <%= item.verdict === 'malicious' ? 'text-red-300' : 'text-emerald-300' %>"><%= item.verdict %></td>
              <td class="px-4 py-3 text-slate-300"><%= Number(item.confidence || 0).toFixed(2) %></td>
              <td class="px-4 py-3 text-slate-300"><%= item.status %></td>
              <td class="px-4 py-3 text-slate-300"><%= new Date(item.timestamp).toLocaleString() %></td>
              <td class="px-4 py-3">
                <div class="flex items-center gap-2">
                  <a href="/history/<%= item.id %>" class="rounded-md border border-sky-400/40 px-3 py-1 text-xs text-sky-200 hover:bg-sky-500/10">View</a>
                  <form action="/history/<%= item.id %>/delete" method="POST" onsubmit="return confirm('Delete this scan record?');">
                    <button type="submit" class="rounded-md border border-red-500/40 px-3 py-1 text-xs text-red-200 hover:bg-red-500/10">Delete</button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </section>
  </main>
</body>
</html>
