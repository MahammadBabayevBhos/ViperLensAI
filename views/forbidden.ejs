<!DOCTYPE html>
<html lang="en" class="h-full bg-slate-950">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/public/css/styles.css" />
</head>
<body class="h-full bg-gradient-to-br from-slate-950 via-slate-900 to-slate-950 text-slate-100">
  <main class="mx-auto flex min-h-screen max-w-lg flex-col items-center justify-center px-6 text-center">
    <p class="text-xs uppercase tracking-[0.3em] text-amber-400">403</p>
    <h1 class="mt-3 text-2xl font-semibold">Access denied</h1>
    <p class="mt-2 text-sm text-slate-400"><%= message %></p>
    <a href="/" class="mt-8 rounded-lg bg-sky-500 px-5 py-2.5 text-sm font-semibold text-slate-950 hover:bg-sky-400">Back to dashboard</a>
  </main>
</body>
</html>
