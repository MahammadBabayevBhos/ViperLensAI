<!DOCTYPE html>
<html lang="en" class="h-full bg-slate-950">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/public/css/styles.css" />
  <style>
    @keyframes checkout-pop {
      0% { transform: scale(0.92); opacity: 0; }
      100% { transform: scale(1); opacity: 1; }
    }
    .checkout-success-panel {
      animation: checkout-pop 420ms cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }
    @keyframes ring-spin {
      to { transform: rotate(360deg); }
    }
    .pay-spinner {
      animation: ring-spin 0.8s linear infinite;
    }
  </style>
</head>
<body class="h-full bg-gradient-to-br from-slate-950 via-slate-900 to-slate-950 text-slate-100 antialiased">
  <div class="min-h-screen px-4 py-10 md:px-8">
    <header class="mx-auto flex max-w-3xl flex-wrap items-center justify-between gap-4 border-b border-slate-800 pb-6">
      <div>
        <p class="text-xs uppercase tracking-[0.25em] text-sky-400">ViperLens Premium</p>
        <h1 class="mt-1 text-2xl font-semibold tracking-tight">Secure checkout</h1>
        <p class="mt-1 text-sm text-slate-400">Simulated payment — no real card data is stored or transmitted to a processor.</p>
      </div>
      <a href="<%= returnTo %>" class="rounded-lg border border-slate-700 px-4 py-2 text-sm text-slate-200 hover:bg-slate-900">Cancel</a>
    </header>

    <main class="mx-auto mt-10 grid max-w-3xl gap-8 lg:grid-cols-5">
      <section class="rounded-2xl border border-slate-800 bg-slate-900/70 p-6 shadow-xl backdrop-blur lg:col-span-2">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-300">Order summary</h2>
        <div class="mt-4 space-y-3 text-sm">
          <div class="flex justify-between text-slate-300">
            <span>ViperLens Premium</span>
            <span class="font-medium text-slate-100"><%= priceLabel %></span>
          </div>
          <div class="flex justify-between text-slate-400">
            <span>Billing</span>
            <span class="capitalize text-slate-300">per <%= intervalLabel %></span>
          </div>
          <div class="border-t border-slate-800 pt-3 flex justify-between text-base font-semibold text-slate-100">
            <span>Due today</span>
            <span><%= priceLabel %></span>
          </div>
        </div>
        <p class="mt-6 text-xs leading-relaxed text-slate-500">
          This is a development simulation. Completing checkout upgrades your account to premium in the local database only.
        </p>
      </section>

      <section class="relative rounded-2xl border border-slate-800 bg-slate-900/80 p-6 shadow-xl backdrop-blur lg:col-span-3">
        <h2 class="text-lg font-semibold text-slate-100">Payment details</h2>
        <p class="mt-1 text-sm text-slate-400">Use any test values — validation is for UX only.</p>

        <form id="checkoutForm" class="mt-6 space-y-4">
          <div>
            <label class="mb-1 block text-xs font-medium uppercase tracking-wide text-slate-400" for="cardName">Name on card</label>
            <input id="cardName" name="cardName" autocomplete="cc-name" required placeholder="Jordan Lee"
              class="w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2.5 text-sm text-slate-100 outline-none ring-sky-500/0 transition focus:border-sky-400 focus:ring-2 focus:ring-sky-500/30" />
          </div>
          <div>
            <label class="mb-1 block text-xs font-medium uppercase tracking-wide text-slate-400" for="cardNumber">Card number</label>
            <input id="cardNumber" name="cardNumber" inputmode="numeric" autocomplete="cc-number" required placeholder="4242 4242 4242 4242"
              class="w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2.5 font-mono text-sm tracking-wide text-slate-100 outline-none focus:border-sky-400 focus:ring-2 focus:ring-sky-500/30" />
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="mb-1 block text-xs font-medium uppercase tracking-wide text-slate-400" for="cardExpiry">Expiry</label>
              <input id="cardExpiry" name="cardExpiry" autocomplete="cc-exp" required placeholder="MM / YY"
                class="w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2.5 text-sm text-slate-100 outline-none focus:border-sky-400 focus:ring-2 focus:ring-sky-500/30" />
            </div>
            <div>
              <label class="mb-1 block text-xs font-medium uppercase tracking-wide text-slate-400" for="cardCvc">CVC</label>
              <input id="cardCvc" name="cardCvc" autocomplete="cc-csc" required placeholder="123"
                class="w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2.5 text-sm text-slate-100 outline-none focus:border-sky-400 focus:ring-2 focus:ring-sky-500/30" />
            </div>
          </div>

          <button type="submit" id="payButton"
            class="relative mt-2 flex w-full items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-sky-500 to-cyan-500 px-4 py-3 text-sm font-semibold text-slate-950 shadow-lg shadow-sky-500/20 transition hover:from-sky-400 hover:to-cyan-400 focus:outline-none focus:ring-2 focus:ring-sky-400 focus:ring-offset-2 focus:ring-offset-slate-900 disabled:cursor-not-allowed disabled:opacity-60">
            <span id="payButtonLabel">Pay <%= priceLabel %></span>
            <span id="paySpinner" class="hidden h-4 w-4 rounded-full border-2 border-slate-900/30 border-t-slate-950 pay-spinner"></span>
          </button>
        </form>

        <div id="successOverlay" class="pointer-events-none absolute inset-0 z-10 hidden flex-col items-center justify-center rounded-2xl bg-slate-950/85 px-6 text-center backdrop-blur-sm">
          <div class="checkout-success-panel max-w-xs rounded-2xl border border-emerald-500/40 bg-emerald-500/10 p-6 shadow-xl">
            <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-emerald-500/20 text-emerald-300">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <p class="mt-3 text-lg font-semibold text-emerald-100">Payment successful</p>
            <p class="mt-1 text-sm text-emerald-200/90">Your account is now Premium. Redirecting…</p>
          </div>
        </div>
      </section>
    </main>
  </div>

  <script>
    (() => {
      const form = document.getElementById('checkoutForm');
      const payButton = document.getElementById('payButton');
      const payButtonLabel = document.getElementById('payButtonLabel');
      const paySpinner = document.getElementById('paySpinner');
      const successOverlay = document.getElementById('successOverlay');
      const returnTo = <%- JSON.stringify(returnTo) %>;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        payButton.disabled = true;
        payButtonLabel.textContent = 'Processing…';
        paySpinner.classList.remove('hidden');

        try {
          await new Promise((r) => setTimeout(r, 900));
          const res = await fetch('/checkout/complete', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Accept': 'application/json'
            },
            body: JSON.stringify({ returnTo })
          });
          const data = await res.json().catch(() => ({}));
          if (!res.ok || !data.ok) {
            throw new Error(data.error || 'Checkout failed');
          }
          successOverlay.classList.remove('hidden');
          successOverlay.classList.add('flex');
          successOverlay.classList.remove('pointer-events-none');
          await new Promise((r) => setTimeout(r, 1400));
          window.location.href = data.redirect || returnTo || '/';
        } catch (err) {
          payButton.disabled = false;
          payButtonLabel.textContent = 'Pay <%= priceLabel %>';
          paySpinner.classList.add('hidden');
          alert(err.message || 'Something went wrong.');
        }
      });
    })();
  </script>
</body>
</html>
